<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Detalle del Pedido</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script>
    if (!localStorage.getItem('user')) window.location.href = '/login';
  </script>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>

  <div class="container py-4">
    <a href="/orders" class="text-decoration-none text-secondary mb-3 d-inline-block">&larr; Volver a Mis Pedidos</a>
    
    <div id="loader" class="text-center py-5">
      <div class="spinner-border text-primary" role="status"></div>
    </div>

    <div id="content" style="display: none;">
      <div class="row">
        <!-- Resumen del Pedido -->
        <div class="col-md-4 mb-4 mb-md-0">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
              <h5 class="card-title fw-bold mb-3">Resumen del Pedido</h5>
              
              <div class="mb-3">
                <small class="text-muted d-block">ID de la Orden</small>
                <code class="text-dark fs-6" id="orderIdLabel"></code>
              </div>

              <div class="mb-3">
                <small class="text-muted d-block">Estado</small>
                <span id="orderStatus" class="badge"></span>
              </div>

              <div class="mb-3">
                <small class="text-muted d-block">Fecha de Creación</small>
                <div id="orderDate" class="fw-bold"></div>
              </div>

              <hr>

              <div class="mb-3">
                <small class="text-muted d-block">Restaurante ID</small>
                <div id="restaurantIdLbl" class="small text-truncate"></div>
              </div>

              <div class="mt-4 p-3 bg-light rounded text-center">
                <span class="d-block text-muted small mb-1">Total Pagado</span>
                <h2 class="text-success mb-0" id="orderTotal"></h2>
              </div>
            </div>
          </div>
        </div>

        <!-- Lista de Artículos (Embebidos) -->
        <div class="col-md-8">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
              <h5 class="fw-bold m-0">Artículos Solicitados</h5>
              <p class="text-muted small">Snapshots históricos (mantienen el precio original)</p>
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th>Cant.</th>
                      <th>Platillo</th>
                      <th class="text-end">Precio Unit.</th>
                      <th class="text-end">Subtotal</th>
                    </tr>
                  </thead>
                  <tbody id="itemsTableBody">
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Extraer el ID de la URL
    const pathParts = window.location.pathname.split('/');
    const orderId = pathParts[pathParts.length - 1];

    async function loadOrder() {
      try {
        const res = await fetch(`/api/orders/${orderId}`);
        const data = await res.json();
        const o = data.order;

        if (!res.ok || !o) {
          document.getElementById('loader').innerHTML = `<div class="alert alert-danger mx-5">Error: ${data.error || 'Pedido no encontrado'}</div>`;
          return;
        }

        document.getElementById('loader').style.display = 'none';
        document.getElementById('content').style.display = 'block';

        document.getElementById('orderIdLabel').textContent = o._id;
        document.getElementById('orderDate').textContent = new Date(o.createdAt).toLocaleString('es-ES');
        document.getElementById('restaurantIdLbl').textContent = o.restaurantId;
        document.getElementById('orderTotal').textContent = `$${parseFloat(o.totalAmount).toFixed(2)}`;

        // Badge Status y Botón de Cancelar
        const st = o.status;
        const b = document.getElementById('orderStatus');
        let cancelBtnHtml = '';
        b.textContent = st.toUpperCase();
        if (st === 'created') {
          b.className = 'badge bg-secondary';
          cancelBtnHtml = `<button class="btn btn-sm btn-outline-danger mt-2 w-100 fw-bold" onclick="cancelOrder('${o._id}')">Cancelar Pedido Abierto (Transacción 2)</button>`;
        }
        else if (st === 'confirmed') b.className = 'badge bg-info';
        else if (st === 'preparing') b.className = 'badge bg-warning text-dark';
        else if (st === 'delivered') b.className = 'badge bg-success';
        else if (st === 'cancelled') b.className = 'badge bg-danger';

        document.getElementById('orderStatus').insertAdjacentHTML('afterend', cancelBtnHtml);

        // Table Items ($pull render)
        const tbody = document.getElementById('itemsTableBody');
        o.items.forEach(item => {
          tbody.innerHTML += `
            <tr>
              <td><span class="badge bg-dark rounded-pill">${item.qty}</span></td>
              <td class="fw-bold">${item.nameSnapshot}</td>
              <td class="text-end text-muted">$${parseFloat(item.unitPriceSnapshot).toFixed(2)}</td>
              <td class="text-end fw-bold text-dark">$${parseFloat(item.lineTotal).toFixed(2)}</td>
              ${o.status === 'created' ? `<td><button class="btn btn-sm btn-danger py-0 px-2" onclick="removeItem('${o._id}', '${item.menuItemId}')" title="$pull">-</button></td>` : '<td></td>'}
            </tr>
          `;
        });

        // Bloque dinámico de Add To Order ($push)
        if (o.status === 'created') {
          const menuRes = await fetch(`/api/menu-items?restaurantId=${o.restaurantId}`);
          const menuData = await menuRes.json();
          let options = `<option value="">Selecciona platillo extra...</option>`;
          if (menuData.menuItems) {
            menuData.menuItems.forEach(mi => {
              options += `<option value="${mi._id}">${mi.name} - $${mi.price}</option>`;
            });
          }
          const addHtml = `
            <tr class="table-light">
              <td><input type="number" id="addQty" class="form-control form-control-sm" value="1" min="1"></td>
              <td colspan="2"><select id="addMenuItem" class="form-select form-select-sm">${options}</select></td>
              <td colspan="2" class="text-end"><button class="btn btn-sm btn-primary" onclick="addItem('${o._id}')">Añadir ($push)</button></td>
            </tr>
          `;
          tbody.innerHTML += addHtml;
        }

      } catch (err) {
        console.error(err);
        document.getElementById('loader').innerHTML = '<div class="alert alert-danger">Error de red</div>';
      }
    }

    // --- ACCIONES CRUD AVANZADAS ---

    // POST Transacción 2 (Cancelar Pedido con AuditLog)
    async function cancelOrder(orderId) {
      if(!confirm('¿Estás seguro de cancelar este pedido abierto (Transaction 2)?')) return;
      
      const user = JSON.parse(localStorage.getItem('user')) || {};
      
      const res = await fetch(`/api/transactions/cancel-order/${orderId}`, {
        method: 'POST', headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ userId: user.id || null, reason: 'Cancelado por el usuario desde la UI (Cliente)' })
      });
      if(res.ok) window.location.reload();
      else alert('Error al procesar la cancelación transaccional');
    }

    // DELETE 1 Array Element ($pull)
    async function removeItem(orderId, menuItemId) {
      if(!confirm('¿Quitar este platillo del carrito? ($pull)')) return;
      const res = await fetch(`/api/orders/${orderId}/items`, {
        method: 'DELETE', headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ menuItemId })
      });
      if(res.ok) window.location.reload();
      else alert('Error eliminando platillo');
    }

    // POST New Array Element ($push)
    async function addItem(orderId) {
      const menuItemId = document.getElementById('addMenuItem').value;
      const qty = parseInt(document.getElementById('addQty').value);
      if(!menuItemId) return alert('Selecciona un platillo para empujar al array');
      
      const res = await fetch(`/api/orders/${orderId}/items`, {
        method: 'POST', headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ menuItemId, qty })
      });
      if(res.ok) window.location.reload();
      else alert((await res.json()).error || 'Error insertando platillo');
    }

    loadOrder();
  </script>
</body>
</html>
