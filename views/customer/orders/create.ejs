<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Nuevo Pedido</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script>
    if (!localStorage.getItem('user')) window.location.href = '/login';
  </script>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>

  <div class="container py-4">
    <h2 class="mb-4">Crear Nuevo Pedido</h2>

    <!-- Filtros de Restaurante -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <div class="row g-2">
          <div class="col-md-4">
            <input type="text" id="search-q" class="form-control" placeholder="Buscar restaurante por nombre..."/>
          </div>
          <div class="col-md-3">
            <select id="filter-category" class="form-select">
              <option value="">Todas las categorias</option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="number" id="filter-rating" class="form-control" placeholder="Rating min." min="1" max="5" step="0.1"/>
          </div>
          <div class="col-md-2">
            <select id="filter-sort" class="form-select">
              <option value="avgRating">Rating (mayor primero)</option>
              <option value="name">Nombre (A-Z)</option>
              <option value="createdAt">Mas nuevos</option>
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-primary w-100" onclick="loadRestaurants(1)">Buscar</button>
          </div>
        </div>
        <div class="row g-2 mt-2">
          <div class="col-md-3">
            <input type="number" id="filter-lat" class="form-control" placeholder="Latitud (ej. 14.6)" step="any"/>
          </div>
          <div class="col-md-3">
            <input type="number" id="filter-lng" class="form-control" placeholder="Longitud (ej. -90.5)" step="any"/>
          </div>
          <div class="col-md-3">
            <input type="number" id="filter-dist" class="form-control" placeholder="Max Distancia (m)" value="5000"/>
          </div>
          <div class="col-md-3 d-flex align-items-center">
            <small class="text-muted">&#128205; Búsqueda Cercana (Geoespacial)</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla de Restaurantes -->
    <div class="card shadow-sm mb-3">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr><th>Nombre</th><th>Categorias</th><th>Rating</th><th>Direccion</th><th></th></tr>
          </thead>
          <tbody id="restaurants-tbody">
            <tr><td colspan="5" class="text-center py-4 text-muted">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <nav class="mb-4" id="pagination-container"></nav>

    <!-- Menú + Carrito (aparece al seleccionar un restaurante) -->
    <div id="order-section" class="d-none">
      <div class="alert alert-success d-flex justify-content-between align-items-center mb-3">
        <span>Restaurante seleccionado: <strong id="selected-rest-name"></strong></span>
        <button class="btn btn-sm btn-outline-secondary" onclick="clearRestaurant()">Cambiar restaurante</button>
      </div>
      <div class="row">
        <!-- Menú Items -->
        <div class="col-md-8">
          <div class="card shadow-sm border-0 mb-4 mb-md-0">
            <div class="card-header bg-dark text-white fw-bold d-flex align-items-center gap-2">
              <span>Platillos del Restaurante</span>
              <input type="text" id="menuSearch" class="form-control form-control-sm ms-auto" style="max-width:220px;"
                placeholder="Buscar platillo..." oninput="searchMenu()"/>
            </div>
            <div class="card-body" id="menuArea">
              <p class="text-muted text-center py-4">Cargando menú...</p>
            </div>
          </div>
        </div>

        <!-- Carrito -->
        <div class="col-md-4">
          <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white fw-bold border-0">Mi Carrito</div>
            <div class="card-body p-0">
              <ul id="cartItems" class="list-group list-group-flush">
                <li class="list-group-item text-center text-muted border-0 py-4">El carrito está vacío.</li>
              </ul>
            </div>
            <div class="card-footer bg-white text-end border-top-0 pt-3">
              <h4 class="text-dark mb-3">Total: $<span id="cartTotal">0.00</span></h4>
              <button id="btnSubmitOrder" class="btn btn-success w-100 fw-bold" disabled>Confirmar Pedido</button>
            </div>
          </div>
          <div id="statusAlert" class="mt-3"></div>
        </div>
      </div>
      <div class="row mt-4">
        <!-- Reseñas del Restaurante -->
        <div class="col-12">
          <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark fw-bold d-flex align-items-center">
              <span>Reseñas de este Restaurante</span>
            </div>
            <div class="card-body" id="reviewsArea">
              <p class="text-muted text-center py-3">Selecciona un restaurante para ver sus reseñas.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let cart = []; // { menuItemId, nameSnapshot, unitPriceSnapshot, qty, lineTotal }
    let currentRestaurant = null;
    let menuSearchTimer;
    let restSearchTimer;

    // ── Filtros / listado de restaurantes ──────────────────────────────────
    async function loadCategories() {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('filter-category');
        (data.values?.categories || []).forEach(c => {
          const opt = document.createElement('option');
          opt.value = c; opt.textContent = c;
          sel.appendChild(opt);
        });
      } catch (_) {}
    }

    async function loadRestaurants(page = 1) {
      const q        = document.getElementById('search-q').value.trim();
      const category = document.getElementById('filter-category').value;
      const rating   = document.getElementById('filter-rating').value.trim();
      const sort     = document.getElementById('filter-sort').value;
      const lat      = document.getElementById('filter-lat').value.trim();
      const lng      = document.getElementById('filter-lng').value.trim();
      const dist     = document.getElementById('filter-dist').value.trim();

      const params = new URLSearchParams({ page, limit: 10, sortBy: sort });
      if (q)        params.set('q', q);
      if (category) params.set('category', category);
      if (rating)   params.set('minRating', rating);

      let url = `/api/restaurants?${params}`;
      if (lat && lng) {
        params.set('lat', lat);
        params.set('lng', lng);
        if (dist) params.set('maxDistance', dist);
        url = `/api/restaurants/nearby?${params}`;
      }

      const res  = await fetch(url);
      const data = await res.json();
      const tbody = document.getElementById('restaurants-tbody');

      if (!data.restaurants?.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">Sin resultados</td></tr>';
        renderPagination(0, 1);
        return;
      }

      tbody.innerHTML = data.restaurants.map(r => `
        <tr class="align-middle">
          <td>
            ${r.image ? `<img src="/api/images/${r.image}" alt="logo" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" class="me-2">` : ''}
            <strong>${r.name}</strong>
          </td>
          <td>${(r.categories || []).join(', ') || '—'}</td>
          <td><span class="badge bg-warning text-dark">${r.avgRating?.toFixed(1) ?? '—'}</span></td>
          <td class="text-muted small">${r.address}</td>
          <td>
            <button class="btn btn-sm btn-dark" onclick="selectRestaurant('${r._id}', \`${r.name.replace(/`/g,'\\`')}\`)">Seleccionar</button>
          </td>
        </tr>`).join('');

      renderPagination(data.pagination.pages, page);
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination-container');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }
      let html = '<ul class="pagination">';
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <button class="page-link" onclick="loadRestaurants(${i})">${i}</button></li>`;
      }
      nav.innerHTML = html + '</ul>';
    }

    document.getElementById('search-q').addEventListener('input', function() {
      clearTimeout(restSearchTimer);
      restSearchTimer = setTimeout(() => loadRestaurants(1), 300);
    });
    document.getElementById('filter-category').addEventListener('change', () => loadRestaurants(1));
    document.getElementById('filter-rating').addEventListener('input', function() {
      clearTimeout(restSearchTimer);
      restSearchTimer = setTimeout(() => loadRestaurants(1), 400);
    });

    // ── Selección de restaurante ────────────────────────────────────────────
    window.selectRestaurant = function(id, name) {
      currentRestaurant = id;
      cart = [];
      updateCartUI();
      document.getElementById('menuSearch').value = '';
      document.getElementById('selected-rest-name').textContent = name;
      document.getElementById('order-section').classList.remove('d-none');
      document.getElementById('order-section').scrollIntoView({ behavior: 'smooth' });
      renderMenu();
      renderReviews(id); // <--- Llama a las reseñas
    };

    window.clearRestaurant = function() {
      currentRestaurant = null;
      cart = [];
      updateCartUI();
      document.getElementById('order-section').classList.add('d-none');
    };

    // ── Menú ────────────────────────────────────────────────────────────────
    async function renderMenu(q = '') {
      const menuArea = document.getElementById('menuArea');
      menuArea.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-dark"></div></div>';

      try {
        const params = new URLSearchParams({ restaurantId: currentRestaurant, limit: 100 });
        if (q) params.set('q', q);
        const res = await fetch(`/api/menu-items?${params}`);
        const data = await res.json();
        
        const available = (data.menuItems || []).filter(i => i.isAvailable);

        if (available.length === 0) {
          menuArea.innerHTML = `<p class="text-center py-4 text-muted">${q ? 'Sin resultados para "' + q + '".' : 'Este restaurante no tiene platillos todavía.'}</p>`;
          return;
        }

        let html = '<div class="row g-3">';
        available.forEach(item => {
          html += `
            <div class="col-sm-6 col-md-4">
              <div class="card h-100 border-0 shadow-sm bg-light">
                ${item.photo ? `<img src="/api/images/${item.photo}" class="card-img-top" style="height: 150px; object-fit: cover;" alt="foto">` : ''}
                <div class="card-body text-center p-3">
                  <h6 class="card-title fw-bold mb-1">${item.name}</h6>
                  <p class="text-primary fw-bold mb-2">$${item.price.toFixed(2)}</p>
                  <button class="btn btn-sm btn-outline-dark" onclick="addToCart('${item._id}', '${item.name}', ${item.price})">Añadir</button>
                </div>
              </div>
            </div>
          `;
        });
        html += '</div>';
        menuArea.innerHTML = html;
      } catch (err) {
        menuArea.innerHTML = '<p class="text-danger">Error al cargar el menú</p>';
      }
    }

    // 2c. Búsqueda con debounce
    window.searchMenu = function() {
      clearTimeout(menuSearchTimer);
      const q = document.getElementById('menuSearch').value.trim();
      menuSearchTimer = setTimeout(() => renderMenu(q), 300);
    };

    // ── Reseñas (Índice Simple) ──────────────────────────────────────────────
    async function renderReviews(restId) {
      const reviewsArea = document.getElementById('reviewsArea');
      reviewsArea.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-warning"></div></div>';

      try {
        // Esta llamada detona el Índice Simple { restaurantId: 1 } en el Backend
        const res = await fetch(`/api/reviews?restaurantId=${restId}&limit=5`);
        const data = await res.json();
        
        if (!data.reviews || data.reviews.length === 0) {
          reviewsArea.innerHTML = '<p class="text-muted text-center py-3">Este restaurante aún no tiene reseñas.</p>';
          return;
        }

        let html = '<div class="list-group">';
        data.reviews.forEach(rev => {
          const stars = '★'.repeat(rev.rating) + '☆'.repeat(5 - rev.rating);
          const dateStr = new Date(rev.createdAt).toLocaleDateString();
          html += `
            <div class="list-group-item list-group-item-action">
              <div class="d-flex w-100 justify-content-between">
                <h6 class="mb-1 text-warning text-shadow-sm">${stars}</h6>
                <small class="text-muted">${dateStr}</small>
              </div>
              <p class="mb-1 small">${rev.comment || '<i>Sin comentario</i>'}</p>
              <small class="text-muted text-capitalize">- ${rev.userId?.name || 'Usuario Anónimo'}</small>
            </div>
          `;
        });
        html += '</div>';
        reviewsArea.innerHTML = html;

      } catch (err) {
        reviewsArea.innerHTML = '<p class="text-danger">Error al cargar las reseñas</p>';
      }
    }

    // ── Carrito ──────────────────────────────────────────────────────────────
    // 3. Manejo del Carrito
    window.addToCart = function(id, name, price) {
      const existing = cart.find(x => x.menuItemId === id);
      if (existing) {
        existing.qty++;
        existing.lineTotal = existing.qty * existing.unitPriceSnapshot;
      } else {
        cart.push({
          menuItemId: id,
          nameSnapshot: name,
          unitPriceSnapshot: price,
          qty: 1,
          lineTotal: price
        });
      }
      updateCartUI();
    };

    window.removeFromCart = function(index) {
      cart.splice(index, 1);
      updateCartUI();
    };

    function updateCartUI() {
      const cartList = document.getElementById('cartItems');
      const totalEl = document.getElementById('cartTotal');
      const btnSubmit = document.getElementById('btnSubmitOrder');
      
      if (cart.length === 0) {
        cartList.innerHTML = '<li class="list-group-item text-center text-muted border-0 py-4">El carrito está vacío.</li>';
        totalEl.textContent = '0.00';
        btnSubmit.disabled = true;
        return;
      }

      let total = 0;
      let html = '';
      cart.forEach((item, index) => {
        total += item.lineTotal;
        html += `
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <span class="badge bg-secondary me-1">${item.qty}x</span>
              <span class="small">${item.nameSnapshot}</span>
            </div>
            <div class="text-end">
              <span class="small fw-bold text-dark me-2">$${item.lineTotal.toFixed(2)}</span>
              <button class="btn btn-sm btn-outline-danger py-0 px-2" onclick="removeFromCart(${index})" title="Quitar">×</button>
            </div>
          </li>
        `;
      });

      cartList.innerHTML = html;
      totalEl.textContent = total.toFixed(2);
      btnSubmit.disabled = false;
    }

    // 4. Submit Order
    document.getElementById('btnSubmitOrder').addEventListener('click', async () => {
      const user = JSON.parse(localStorage.getItem('user'));
      
      const payload = {
        userId: user.id,
        restaurantId: currentRestaurant,
        totalAmount: cart.reduce((acc, curr) => acc + curr.lineTotal, 0),
        status: 'created',
        items: cart
      };

      const btn = document.getElementById('btnSubmitOrder');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Procesando...';

      try {
        const res = await fetch('/api/orders', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(payload)
        });
        
        const data = await res.json();
        
        if (res.ok) {
          document.getElementById('statusAlert').innerHTML = `
            <div class="alert alert-success">¡Pedido creado! ID: <strong>Oculto por seguridad</strong> <br>Redirigiendo...</div>
          `;
          setTimeout(() => window.location.href = '/orders', 2000);
        } else {
          document.getElementById('statusAlert').innerHTML = `<div class="alert alert-danger">${data.error || 'Error'}</div>`;
          btn.disabled = false;
          btn.textContent = 'Confirmar Pedido';
        }
      } catch (err) {
        document.getElementById('statusAlert').innerHTML = `<div class="alert alert-danger">Fallo de conexión</div>`;
        btn.disabled = false;
        btn.textContent = 'Confirmar Pedido';
      }
    });

    // Boot
    loadCategories();
    loadRestaurants(1);
  </script>
</body>
</html>
