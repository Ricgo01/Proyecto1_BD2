<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Restaurantes Cercanos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <script>
    const _u = JSON.parse(localStorage.getItem('user') || '{}');
    if (!_u.id) window.location.href = '/login';
  </script>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4">
    <h2 class="mb-1">Restaurantes Cercanos</h2>
    <p class="text-muted mb-4 small">Encuentra los restaurantes más cerca de ti en tiempo real.</p>

    <!-- Controles de búsqueda -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="row g-3 align-items-end">
          <div class="col-12">
            <button class="btn btn-primary" onclick="useMyLocation()">
              📍 Usar mi ubicación actual
            </button>
            <span id="location-status" class="ms-3 text-muted small"></span>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Latitud</label>
            <input type="number" id="lat" class="form-control" placeholder="Ej: 14.6349" step="any"/>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-semibold small">Longitud</label>
            <input type="number" id="lng" class="form-control" placeholder="Ej: -90.5069" step="any"/>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-semibold small">
              Distancia máxima: <strong id="dist-label">5 km</strong>
            </label>
            <input type="range" id="maxDistance" class="form-range" min="500" max="20000" step="500" value="5000"
              oninput="document.getElementById('dist-label').textContent = (this.value/1000).toFixed(1)+' km'"/>
          </div>
          <div class="col-md-2">
            <button class="btn btn-success w-100" onclick="search()">Buscar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Estado / mapa indicativo -->
    <div id="results-header" class="d-none mb-2 text-muted small"></div>

    <!-- Resultados -->
    <div id="results" class="row g-3">
      <div class="col-12 text-center text-muted py-5">
        <p class="fs-5">Activa tu ubicación o ingresa coordenadas para encontrar restaurantes cercanos.</p>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function useMyLocation() {
      const statusEl = document.getElementById('location-status');
      if (!navigator.geolocation) {
        statusEl.textContent = 'Geolocalización no soportada en este navegador.';
        return;
      }
      statusEl.textContent = 'Obteniendo ubicación...';
      navigator.geolocation.getCurrentPosition(
        pos => {
          document.getElementById('lat').value = pos.coords.latitude.toFixed(6);
          document.getElementById('lng').value = pos.coords.longitude.toFixed(6);
          statusEl.innerHTML = `<span class="text-success">✓ Ubicación obtenida (precisión: ±${Math.round(pos.coords.accuracy)} m)</span>`;
          search();
        },
        err => {
          const msgs = {
            1: 'Permiso denegado. Ingresa las coordenadas manualmente.',
            2: 'Posición no disponible.',
            3: 'Tiempo de espera agotado.'
          };
          statusEl.innerHTML = `<span class="text-danger">${msgs[err.code] || 'Error desconocido.'}</span>`;
        },
        { enableHighAccuracy: true, timeout: 10000 }
      );
    }

    async function search() {
      const lat = parseFloat(document.getElementById('lat').value);
      const lng = parseFloat(document.getElementById('lng').value);
      const maxDistance = parseInt(document.getElementById('maxDistance').value, 10);
      const resultsEl = document.getElementById('results');

      if (isNaN(lat) || isNaN(lng)) {
        resultsEl.innerHTML = '<div class="col-12"><div class="alert alert-warning">Ingresa coordenadas válidas.</div></div>';
        return;
      }

      resultsEl.innerHTML = '<div class="col-12 text-center py-4"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted">Buscando restaurantes...</p></div>';

      try {
        const res  = await fetch(`/api/restaurants/nearby?lat=${lat}&lng=${lng}&maxDistance=${maxDistance}`);
        const data = await res.json();
        const list = data.restaurants || data || [];

        const header = document.getElementById('results-header');
        header.className = 'mb-2 text-muted small';
        header.textContent = `${list.length} restaurante(s) encontrado(s) en un radio de ${(maxDistance/1000).toFixed(1)} km`;

        if (!list.length) {
          resultsEl.innerHTML = `
            <div class="col-12 text-center py-5">
              <div class="fs-1">🍽️</div>
              <p class="text-muted">No se encontraron restaurantes en ese radio. Intenta aumentar la distancia.</p>
            </div>`;
          return;
        }

        resultsEl.innerHTML = list.map(r => {
          const stars = '★'.repeat(Math.round(r.rating || 0)) + '☆'.repeat(5 - Math.round(r.rating || 0));
          const cats  = (r.categories || []).map(c => `<span class="badge bg-secondary me-1">${c}</span>`).join('');
          const imgUrl = r.imageId ? `/api/images/${r.imageId}` : null;
          const dist  = r.distance != null ? `<span class="badge bg-info text-dark">${(r.distance/1000).toFixed(2)} km</span>` : '';

          return `
            <div class="col-md-6 col-lg-4">
              <div class="card shadow-sm h-100">
                ${imgUrl ? `<img src="${imgUrl}" class="card-img-top" style="height:160px;object-fit:cover" alt="${r.name}" onerror="this.style.display='none'">` : ''}
                <div class="card-body d-flex flex-column">
                  <div class="d-flex justify-content-between align-items-start mb-1">
                    <h5 class="card-title mb-0">${r.name}</h5>
                    ${dist}
                  </div>
                  <div class="text-warning mb-1">${stars} <small class="text-muted">(${(r.rating || 0).toFixed(1)})</small></div>
                  <div class="mb-2">${cats || '<span class="text-muted small">Sin categorías</span>'}</div>
                  <p class="text-muted small mb-3">
                    ${r.address ? r.address : ''}
                    ${r.location?.coordinates ? `<br><code class="small">${r.location.coordinates[1].toFixed(5)}, ${r.location.coordinates[0].toFixed(5)}</code>` : ''}
                  </p>
                  <div class="mt-auto d-flex gap-2">
                    <a href="/restaurants/${r._id}" class="btn btn-sm btn-outline-dark">Ver Detalles</a>
                    <a href="/orders/create" class="btn btn-sm btn-primary" onclick="sessionStorage.setItem('preselectedRestaurant', JSON.stringify({id:'${r._id}',name:${JSON.stringify(r.name)}}))">Crear Pedido</a>
                  </div>
                </div>
              </div>
            </div>`;
        }).join('');
      } catch (err) {
        resultsEl.innerHTML = '<div class="col-12"><div class="alert alert-danger">Error al buscar restaurantes cercanos.</div></div>';
        console.error(err);
      }
    }
  </script>
</body>
</html>
