<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Food Delivery App</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 0;
    }
    .auth-container {
      max-width: 420px;
      width: 100%;
      padding: 2rem;
      background: white;
      border-radius: 10px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
  </style>
</head>
<body>

  <div class="auth-container">

    <!-- TAB HEADERS -->
    <ul class="nav nav-tabs mb-4" id="authTabs">
      <li class="nav-item">
        <button class="nav-link active" id="tab-login" onclick="showTab('login')">Iniciar Sesión</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" id="tab-register" onclick="showTab('register')">Crear Cuenta</button>
      </li>
    </ul>

    <div id="alertPlaceholder"></div>

    <!-- LOGIN PANEL -->
    <div id="panel-login">
      <form id="loginForm">
        <div class="mb-3">
          <label for="email" class="form-label">Correo Electrónico</label>
          <input type="text" class="form-control" id="email" required placeholder="tu@email.com">
        </div>
        <button type="submit" class="btn btn-primary w-100">Ingresar</button>
      </form>
    </div>

    <!-- REGISTER PANEL -->
    <div id="panel-register" class="d-none">
      <form id="registerForm">
        <div class="mb-3">
          <label for="reg-name" class="form-label">Nombre completo *</label>
          <input type="text" class="form-control" id="reg-name" required placeholder="Juan Pérez">
        </div>
        <div class="mb-3">
          <label for="reg-email" class="form-label">Correo Electrónico *</label>
          <input type="text" class="form-control" id="reg-email" required placeholder="tu@email.com">
        </div>
        <div class="alert alert-info py-2 small">
          Las nuevas cuentas se crean con rol <strong>Customer</strong>.
        </div>
        <button type="submit" class="btn btn-success w-100">Registrarse</button>
      </form>
    </div>

  </div>

  <script>
    function showTab(tab) {
      document.getElementById('panel-login').classList.toggle('d-none',    tab !== 'login');
      document.getElementById('panel-register').classList.toggle('d-none', tab !== 'register');
      document.getElementById('tab-login').classList.toggle('active',    tab === 'login');
      document.getElementById('tab-register').classList.toggle('active', tab === 'register');
      document.getElementById('alertPlaceholder').innerHTML = '';
    }

    // ── Login ──────────────────────────────────────────────────────────────
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value.trim();
      const alertPlaceholder = document.getElementById('alertPlaceholder');

      try {
        const response = await fetch(`/api/users/email/${encodeURIComponent(email)}`);
        const data = await response.json();

        if (response.ok && data.user) {
          localStorage.setItem('user', JSON.stringify({
            id:    data.user._id,
            name:  data.user.name,
            email: data.user.email,
            role:  data.user.role
          }));
          window.location.href = '/';
        } else {
          alertPlaceholder.innerHTML = `<div class="alert alert-danger">Usuario no encontrado. ¿Deseas <a href="#" onclick="showTab('register')">crear una cuenta</a>?</div>`;
        }
      } catch (error) {
        alertPlaceholder.innerHTML = `<div class="alert alert-danger">Error de conexión</div>`;
      }
    });

    // ── Register ───────────────────────────────────────────────────────────
    document.getElementById('registerForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertPlaceholder = document.getElementById('alertPlaceholder');
      const name  = document.getElementById('reg-name').value.trim();
      const email = document.getElementById('reg-email').value.trim();

      try {
        const res  = await fetch('/api/users', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, role: 'customer' })
        });
        const data = await res.json();

        if (res.ok) {
          // Auto-login after registration
          localStorage.setItem('user', JSON.stringify({
            id:    data.user._id,
            name:  data.user.name,
            email: data.user.email,
            role:  data.user.role
          }));
          window.location.href = '/';
        } else {
          const msg = data.error?.message || data.error || 'Error al registrarse';
          alertPlaceholder.innerHTML = `<div class="alert alert-danger">${msg.includes('duplicate') || msg.includes('E11000') ? 'Este correo ya está registrado.' : msg}</div>`;
        }
      } catch (err) {
        alertPlaceholder.innerHTML = `<div class="alert alert-danger">Error de conexión</div>`;
      }
    });

    // Si ya hay sesión iniciada, redirigir
    if (localStorage.getItem('user')) {
      window.location.href = '/';
    }
  </script>
</body>
</html>
