<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Menu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <style>
    .suggestion-box { position:absolute; z-index:1000; width:100%; max-height:200px; overflow-y:auto; }
    .suggestion-item { cursor:pointer; padding:8px 12px; border-bottom:1px solid #eee; background:#fff; }
    .suggestion-item:hover { background:#f0f4ff; }
  </style>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Menu</h2>
      <a href="/menu/create" class="btn btn-dark">+ Nuevo Item</a>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="row g-2">
          <!-- Restaurant dropdown -->
          <div class="col-md-4">
            <select id="filter-restaurantId" class="form-select">
              <option value="">Todos mis restaurantes</option>
            </select>
          </div>
          <!-- Name search -->
          <div class="col-md-3">
            <input type="text" id="filter-name" class="form-control" placeholder="Buscar por nombre..."/>
          </div>
          <!-- Tag dropdown -->
          <div class="col-md-2">
            <select id="filter-tag" class="form-select">
              <option value="">Todos los tags</option>
            </select>
          </div>
          <!-- Availability -->
          <div class="col-md-2">
            <select id="filter-available" class="form-select">
              <option value="">Disponibilidad</option>
              <option value="true">Solo disponibles</option>
              <option value="false">No disponibles</option>
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-primary w-100" onclick="loadMenu(1)">Buscar</button>
          </div>
        </div>
      </div>
    </div>

    <div id="alert" class="d-none mb-3"></div>

    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr><th>Nombre</th><th>Precio</th><th>Tags</th><th>Disponible</th><th>Acciones</th></tr>
          </thead>
          <tbody id="menu-tbody">
            <tr><td colspan="5" class="text-center py-4 text-muted">Usa los filtros para buscar</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <nav class="mt-3" id="pagination-container"></nav>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let restTimer, nameTimer;

    // Load tags into dropdown
    async function loadTags() {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('filter-tag');
        (data.values?.tags || []).forEach(t => {
          const opt = document.createElement('option');
          opt.value = t; opt.textContent = t;
          sel.appendChild(opt);
        });
      } catch (_) {}
    }

    // Load Owner's Restaurants into Dropdown
    async function loadOwnerRestaurants() {
      const user = JSON.parse(localStorage.getItem('user'));
      try {
        const res = await fetch(`/api/restaurants?owner_id=${user.id}&limit=100`);
        const data = await res.json();
        const sel = document.getElementById('filter-restaurantId');
        if (data.restaurants) {
          data.restaurants.forEach(r => {
            const opt = document.createElement('option');
            opt.value = r._id;
            opt.textContent = r.name;
            sel.appendChild(opt);
          });
        }
        
        // Pre-fill from URL param if present
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('restaurantId')) {
          sel.value = urlParams.get('restaurantId');
        }
        
        // Cargar menú después de tener la lista
        loadMenu(1);
      } catch (err) {
        console.error("Error loading restaurants", err);
      }
    }

    document.getElementById('filter-name').addEventListener('input', function() {
      clearTimeout(nameTimer);
      nameTimer = setTimeout(() => loadMenu(1), 300);
    });

    document.getElementById('filter-restaurantId').addEventListener('change', () => loadMenu(1));
    document.getElementById('filter-tag').addEventListener('change', () => loadMenu(1));
    document.getElementById('filter-available').addEventListener('change', () => loadMenu(1));

    async function loadMenu(page = 1) {
      const restaurantId = document.getElementById('filter-restaurantId').value.trim();
      const nameQ        = document.getElementById('filter-name').value.trim();
      const isAvailable  = document.getElementById('filter-available').value;
      const tag          = document.getElementById('filter-tag').value;

      const params = new URLSearchParams({ page, limit: 20 });
      if (restaurantId) params.set('restaurantId', restaurantId);
      if (nameQ)        params.set('q', nameQ);
      if (isAvailable !== '') params.set('isAvailable', isAvailable);
      if (tag)          params.set('tag', tag);

      const res  = await fetch(`/api/menu-items?${params}`);
      const data = await res.json();
      const tbody = document.getElementById('menu-tbody');

      if (!data.menuItems?.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">Sin resultados</td></tr>';
        renderPagination(0, 1); return;
      }

      tbody.innerHTML = data.menuItems.map(m => `
        <tr class="align-middle">
          <td>
            ${m.photo ? `<img src="/api/images/${m.photo}" alt="foto" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" class="me-2">` : ''}
            ${m.name}
          </td>
          <td>Q${m.price?.toFixed(2)}</td>
          <td>${(m.tags||[]).map(t=>`<span class="badge bg-info text-dark me-1">${t}</span>`).join('') || '—'}</td>
          <td>
            <button class="btn btn-sm ${m.isAvailable ? 'btn-success' : 'btn-secondary'}"
              onclick="toggleAvailability('${m._id}', ${m.isAvailable})">
              ${m.isAvailable ? 'Disponible' : 'No disponible'}
            </button>
          </td>
          <td>
            <a href="/menu/${m._id}/edit" class="btn btn-sm btn-outline-secondary">Editar</a>
          </td>
        </tr>`).join('');

      renderPagination(data.pagination.pages, page);
    }

    async function toggleAvailability(id, current) {
      const alertEl = document.getElementById('alert');
      const res = await fetch(`/api/menu-items/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ isAvailable: !current })
      });
      if (res.ok) {
        loadMenu(1);
      } else {
        alertEl.className = 'alert alert-danger';
        alertEl.textContent = 'Error al actualizar disponibilidad';
        alertEl.classList.remove('d-none');
      }
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination-container');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }
      let html = '<ul class="pagination">';
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <button class="page-link" onclick="loadMenu(${i})">${i}</button></li>`;
      }
      nav.innerHTML = html + '</ul>';
    }

    loadTags();
    loadOwnerRestaurants();
  </script>
</body>
</html>
