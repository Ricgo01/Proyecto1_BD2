<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Editar Item</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4" style="max-width:600px">
    <a href="/menu" class="btn btn-sm btn-outline-secondary mb-3">← Volver</a>
    <h2 class="mb-4">Editar Item de Menu</h2>
    <div id="alert" class="d-none"></div>
    <div class="card shadow-sm">
      <div class="card-body">
        <form id="form-edit">
          <div class="mb-3">
            <label class="form-label fw-semibold">Nombre *</label>
            <input type="text" id="name" class="form-control" required/>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Precio *</label>
            <input type="number" id="price" class="form-control" required step="0.01" min="0"/>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Tags</label>
            <input type="text" id="tags" class="form-control" placeholder="separados por coma"/>
          </div>
          <div class="mb-3 form-check">
            <input type="checkbox" id="isAvailable" class="form-check-input"/>
            <label class="form-check-label" for="isAvailable">Disponible</label>
          </div>
          <button type="submit" class="btn btn-dark w-100">Guardar Cambios</button>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const itemId = window.location.pathname.split('/')[2]; // /menu/:id/edit

    async function loadItem() {
      const res  = await fetch(`/api/menu-items/${itemId}`);
      const data = await res.json();
      if (!res.ok) return;
      const m = data.menuItem;
      document.getElementById('name').value        = m.name;
      document.getElementById('price').value       = m.price;
      document.getElementById('tags').value        = (m.tags||[]).join(', ');
      document.getElementById('isAvailable').checked = m.isAvailable;
    }

    document.getElementById('form-edit').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertEl = document.getElementById('alert');
      const body = {
        name:        document.getElementById('name').value.trim(),
        price:       parseFloat(document.getElementById('price').value),
        tags:        document.getElementById('tags').value.split(',').map(t=>t.trim()).filter(Boolean),
        isAvailable: document.getElementById('isAvailable').checked
      };
      const res  = await fetch(`/api/menu-items/${itemId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (res.ok) {
        alertEl.className = 'alert alert-success';
        alertEl.textContent = 'Item actualizado';
        alertEl.classList.remove('d-none');
        setTimeout(() => history.back(), 1500);
      } else {
        alertEl.className = 'alert alert-danger';
        alertEl.textContent = data.error?.message || 'Error al actualizar';
        alertEl.classList.remove('d-none');
      }
    });

    loadItem();
  </script>
</body>
</html>
