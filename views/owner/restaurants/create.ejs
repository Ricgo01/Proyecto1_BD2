<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Crear Restaurante</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <style>
    .suggestion-box { position:absolute; z-index:1000; width:100%; max-height:200px; overflow-y:auto; }
    .suggestion-item { cursor:pointer; padding:8px 12px; border-bottom:1px solid #eee; background:#fff; }
    .suggestion-item:hover { background:#f0f4ff; }
  </style>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4" style="max-width:620px">
    <a href="/restaurants" class="btn btn-sm btn-outline-secondary mb-3">← Volver</a>
    <h2 class="mb-4">Nuevo Restaurante</h2>

    <div id="alert" class="d-none"></div>

    <div class="card shadow-sm">
      <div class="card-body">
        <form id="form-create">
          <div class="mb-3">
            <label class="form-label fw-semibold">Nombre *</label>
            <input type="text" id="name" class="form-control" required placeholder="Ej: Tacos El Gordo"/>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Direccion *</label>
            <input type="text" id="address" class="form-control" required placeholder="Av. Reforma 123, CDMX"/>
          </div>

          <!-- Owner search -->
          <div class="mb-3 position-relative">
            <label class="form-label fw-semibold">Owner *</label>
            <input type="text" id="owner-search" class="form-control" placeholder="Escribe el nombre del owner..." autocomplete="off"/>
            <input type="hidden" id="owner_id"/>
            <div id="owner-suggestions" class="suggestion-box border rounded d-none"></div>
            <div id="owner-selected" class="mt-1 small text-success d-none"></div>
          </div>

          <div class="row mb-3">
            <div class="col">
              <label class="form-label fw-semibold">Longitud *</label>
              <input type="number" id="lng" class="form-control" step="any" required placeholder="-90.5133"/>
            </div>
            <div class="col">
              <label class="form-label fw-semibold">Latitud *</label>
              <input type="number" id="lat" class="form-control" step="any" required placeholder="14.6349"/>
            </div>
          </div>

          <!-- Categories from API -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Categorias</label>
            <select id="categories-select" class="form-select" multiple size="4"></select>
            <div class="form-text">Mantén Ctrl (o Cmd) para seleccionar varias. Puedes agregar nuevas abajo.</div>
            <input type="text" id="categories-custom" class="form-control mt-2" placeholder="Categorias adicionales (separadas por coma)"/>
          </div>

          <button type="submit" class="btn btn-dark w-100">Crear Restaurante</button>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let ownerTimer;

    // Load existing categories
    async function loadCategories() {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('categories-select');
        (data.values?.categories || []).forEach(c => {
          const opt = document.createElement('option');
          opt.value = c; opt.textContent = c;
          sel.appendChild(opt);
        });
      } catch (_) {}
    }

    // Owner search
    document.getElementById('owner-search').addEventListener('input', function() {
      clearTimeout(ownerTimer);
      const q = this.value.trim();
      document.getElementById('owner_id').value = '';
      document.getElementById('owner-selected').classList.add('d-none');
      if (q.length < 1) {
        document.getElementById('owner-suggestions').classList.add('d-none');
        return;
      }
      ownerTimer = setTimeout(() => searchOwners(q), 250);
    });

    async function searchOwners(q) {
      try {
        const res  = await fetch(`/api/users?q=${encodeURIComponent(q)}&limit=8`);
        const data = await res.json();
        const box  = document.getElementById('owner-suggestions');
        if (!data.users?.length) {
          box.innerHTML = '<div class="suggestion-item text-muted">Sin resultados</div>';
        } else {
          box.innerHTML = data.users.map(u =>
            `<div class="suggestion-item" onclick="selectOwner('${u._id}','${u.name.replace(/'/g,"\\'")} (${u.email})')">
               <strong>${u.name}</strong> <span class="text-muted small">${u.email}</span>
               <span class="badge bg-secondary ms-1">${u.role}</span>
             </div>`
          ).join('');
        }
        box.classList.remove('d-none');
      } catch (_) {}
    }

    function selectOwner(id, label) {
      document.getElementById('owner_id').value = id;
      document.getElementById('owner-search').value = label;
      const sel = document.getElementById('owner-selected');
      sel.textContent = 'Owner seleccionado';
      sel.classList.remove('d-none');
      document.getElementById('owner-suggestions').classList.add('d-none');
    }

    document.addEventListener('click', (e) => {
      if (!e.target.closest('#owner-search') && !e.target.closest('#owner-suggestions'))
        document.getElementById('owner-suggestions').classList.add('d-none');
    });

    document.getElementById('form-create').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertEl = document.getElementById('alert');
      const owner_id = document.getElementById('owner_id').value.trim();
      if (!owner_id) {
        alertEl.className = 'alert alert-warning';
        alertEl.textContent = 'Selecciona un owner de la lista';
        alertEl.classList.remove('d-none');
        return;
      }

      // Collect categories: selected from list + custom typed ones
      const selectedOpts   = Array.from(document.getElementById('categories-select').selectedOptions).map(o => o.value);
      const customCats     = document.getElementById('categories-custom').value.split(',').map(c => c.trim()).filter(Boolean);
      const allCategories  = [...new Set([...selectedOpts, ...customCats])];

      const body = {
        name:       document.getElementById('name').value.trim(),
        address:    document.getElementById('address').value.trim(),
        owner_id,
        location: {
          type: 'Point',
          coordinates: [
            parseFloat(document.getElementById('lng').value),
            parseFloat(document.getElementById('lat').value)
          ]
        },
        categories: allCategories
      };

      try {
        const res  = await fetch('/api/restaurants', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (res.ok) {
          alertEl.className = 'alert alert-success';
          alertEl.textContent = `Restaurante creado: ${data.restaurant.name}`;
          alertEl.classList.remove('d-none');
          setTimeout(() => window.location.href = '/restaurants', 1500);
        } else {
          alertEl.className = 'alert alert-danger';
          alertEl.textContent = data.error?.message || data.error || 'Error al crear';
          alertEl.classList.remove('d-none');
        }
      } catch (err) {
        alertEl.className = 'alert alert-danger';
        alertEl.textContent = 'Error de conexion';
        alertEl.classList.remove('d-none');
      }
    });

    loadCategories();
  </script>
</body>
</html>
