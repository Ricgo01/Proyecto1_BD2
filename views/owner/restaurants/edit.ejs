<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Editar Restaurante</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4" style="max-width:640px">
    <a href="/restaurants" class="btn btn-sm btn-outline-secondary mb-3">← Volver</a>
    <h2 class="mb-4">Editar Restaurante</h2>

    <div id="alert" class="d-none"></div>

    <div class="card shadow-sm">
      <div class="card-body">
        <form id="form-edit">

          <div class="mb-3">
            <label class="form-label fw-semibold">Nombre *</label>
            <input type="text" id="name" class="form-control" required placeholder="Ej: Tacos El Gordo"/>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Dirección *</label>
            <input type="text" id="address" class="form-control" required placeholder="Av. Reforma 123, CDMX"/>
          </div>

          <!-- Imagen actual + nueva -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Logo / Imagen</label>
            <div id="current-image-preview" class="mb-2 d-none">
              <p class="form-text mb-1">Imagen actual:</p>
              <img id="preview-img" src="" alt="logo actual"
                   style="height:90px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6;">
            </div>
            <input type="file" id="image" class="form-control" accept="image/*"/>
            <div class="form-text">Selecciona una nueva imagen para reemplazar la actual. Si no seleccionas nada, la imagen existente se conserva.</div>
          </div>

          <div class="row mb-3">
            <div class="col">
              <label class="form-label fw-semibold">Longitud *</label>
              <input type="number" id="lng" class="form-control" step="any" required placeholder="-90.5133"/>
            </div>
            <div class="col">
              <label class="form-label fw-semibold">Latitud *</label>
              <input type="number" id="lat" class="form-control" step="any" required placeholder="14.6349"/>
            </div>
          </div>

          <!-- Categorías -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Categorías</label>
            <select id="categories-select" class="form-select" multiple size="4"></select>
            <div class="form-text">Mantén Ctrl (o Cmd) para seleccionar varias.</div>
            <input type="text" id="categories-custom" class="form-control mt-2"
              placeholder="Categorías adicionales (separadas por coma)"/>
          </div>

          <button type="submit" class="btn btn-dark w-100">Guardar Cambios</button>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const restaurantId = window.location.pathname.split('/')[2]; // /restaurants/:id/edit
    const currentUser  = JSON.parse(localStorage.getItem('user')) || {};
    let existingImageId = null;

    // Load existing categories into the multi-select
    async function loadCategories(existingCats = []) {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('categories-select');
        const all  = new Set([...(data.values?.categories || []), ...existingCats]);
        all.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c;
          opt.textContent = c;
          if (existingCats.includes(c)) opt.selected = true;
          sel.appendChild(opt);
        });
      } catch (_) {}
    }

    // Pre-populate form with current restaurant data
    async function loadRestaurant() {
      const alertEl = document.getElementById('alert');
      try {
        const res  = await fetch(`/api/restaurants/${restaurantId}`);
        const data = await res.json();
        if (!res.ok) throw new Error(data.error?.message || 'No encontrado');

        const r = data.restaurant;

        // Ownership guard
        const ownerId = r.owner_id?._id ?? r.owner_id;
        if (currentUser.id && ownerId && ownerId.toString() !== currentUser.id.toString()) {
          alertEl.className = 'alert alert-danger';
          alertEl.textContent = 'No tienes permiso para editar este restaurante.';
          alertEl.classList.remove('d-none');
          document.getElementById('form-edit').classList.add('d-none');
          return;
        }

        document.getElementById('name').value    = r.name || '';
        document.getElementById('address').value = r.address || '';
        document.getElementById('lng').value     = r.location?.coordinates?.[0] ?? '';
        document.getElementById('lat').value     = r.location?.coordinates?.[1] ?? '';

        // Image preview
        if (r.image) {
          existingImageId = r.image;
          document.getElementById('preview-img').src = `/api/images/${r.image}`;
          document.getElementById('current-image-preview').classList.remove('d-none');
        }

        await loadCategories(r.categories || []);

      } catch (err) {
        alertEl.className = 'alert alert-danger';
        alertEl.textContent = 'Error cargando datos: ' + err.message;
        alertEl.classList.remove('d-none');
      }
    }

    document.getElementById('form-edit').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertEl = document.getElementById('alert');

      // Collect categories
      const selectedOpts = Array.from(document.getElementById('categories-select').selectedOptions).map(o => o.value);
      const customCats   = document.getElementById('categories-custom').value.split(',').map(c => c.trim()).filter(Boolean);
      const allCategories = [...selectedOpts, ...customCats];

      // Image upload (only if new file selected)
      let finalImageId = existingImageId;
      const imageInput = document.getElementById('image');
      if (imageInput.files.length > 0) {
        alertEl.className = 'alert alert-info';
        alertEl.textContent = 'Subiendo imagen a GridFS...';
        alertEl.classList.remove('d-none');

        const fd = new FormData();
        fd.append('image', imageInput.files[0]);

        try {
          const upRes  = await fetch('/api/images/upload', { method: 'POST', body: fd });
          const upData = await upRes.json();
          if (upRes.ok) finalImageId = upData.fileId;
          else throw new Error(upData.error);
        } catch (err) {
          alertEl.className = 'alert alert-danger';
          alertEl.textContent = 'Error subiendo la imagen: ' + err.message;
          return;
        }
      }

      const body = {
        name:    document.getElementById('name').value.trim(),
        address: document.getElementById('address').value.trim(),
        image:   finalImageId,
        location: {
          type: 'Point',
          coordinates: [
            parseFloat(document.getElementById('lng').value),
            parseFloat(document.getElementById('lat').value)
          ]
        },
        categories: allCategories
      };

      try {
        const res  = await fetch(`/api/restaurants/${restaurantId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'x-user-id': currentUser.id || ''
          },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (res.ok) {
          alertEl.className = 'alert alert-success';
          alertEl.textContent = `Restaurante actualizado: ${data.restaurant.name}`;
          alertEl.classList.remove('d-none');
          setTimeout(() => window.location.href = `/restaurants/${restaurantId}`, 1800);
        } else {
          alertEl.className = 'alert alert-danger';
          alertEl.textContent = data.error?.message || data.error || 'Error al guardar';
          alertEl.classList.remove('d-none');
        }
      } catch (err) {
        alertEl.className = 'alert alert-danger';
        alertEl.textContent = 'Error de conexión';
        alertEl.classList.remove('d-none');
      }
    });

    loadRestaurant();
  </script>
</body>
</html>
