<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Restaurantes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Restaurantes</h2>
      <a href="/restaurants/create" class="btn btn-dark">+ Nuevo</a>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="row g-2">
          <div class="col-md-4">
            <input type="text" id="search-q" class="form-control" placeholder="Buscar por nombre..."/>
          </div>
          <div class="col-md-3">
            <select id="filter-category" class="form-select">
              <option value="">Todas las categorias</option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="number" id="filter-rating" class="form-control" placeholder="Rating min." min="1" max="5" step="0.1"/>
          </div>
          <div class="col-md-2">
            <select id="filter-sort" class="form-select">
              <option value="avgRating">Rating (mayor primero)</option>
              <option value="name">Nombre (A-Z)</option>
              <option value="createdAt">Mas nuevos</option>
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-primary w-100" onclick="loadRestaurants(1)">Buscar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla -->
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr><th>Nombre</th><th>Categorias</th><th>Rating</th><th>Direccion</th><th></th></tr>
          </thead>
          <tbody id="restaurants-tbody">
            <tr><td colspan="5" class="text-center py-4 text-muted">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Paginacion -->
    <nav class="mt-3" id="pagination-container"></nav>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentPage = 1;
    let searchTimer;

    // Load categories into dropdown
    async function loadCategories() {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('filter-category');
        if (data.values?.categories?.length) {
          data.values.categories.forEach(c => {
            const opt = document.createElement('option');
            opt.value = c;
            opt.textContent = c;
            sel.appendChild(opt);
          });
        }
      } catch (_) {}
    }

    async function loadRestaurants(page = 1) {
      currentPage = page;
      const q        = document.getElementById('search-q').value.trim();
      const category = document.getElementById('filter-category').value;
      const rating   = document.getElementById('filter-rating').value.trim();
      const sort     = document.getElementById('filter-sort').value;
      const user     = JSON.parse(localStorage.getItem('user'));

      const params = new URLSearchParams({ page, limit: 10, sortBy: sort, owner_id: user.id });
      if (q)        params.set('q', q);
      if (category) params.set('category', category);
      if (rating)   params.set('minRating', rating);

      const res  = await fetch(`/api/restaurants?${params}`);
      const data = await res.json();
      const tbody = document.getElementById('restaurants-tbody');

      if (!data.restaurants?.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">Sin resultados</td></tr>';
        renderPagination(0, 1);
        return;
      }

      tbody.innerHTML = data.restaurants.map(r => `
        <tr class="align-middle">
          <td>
            ${r.image ? `<img src="/api/images/${r.image}" alt="logo" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" class="me-2">` : ''}
            <strong>${r.name}</strong>
          </td>
          <td>${(r.categories || []).join(', ') || '—'}</td>
          <td><span class="badge bg-warning text-dark">${r.avgRating?.toFixed(1) ?? '—'}</span></td>
          <td class="text-muted small">${r.address}</td>
          <td>
            <a href="/restaurants/${r._id}" class="btn btn-sm btn-outline-dark">Ver</a>
          </td>
        </tr>`).join('');

      renderPagination(data.pagination.pages, page);
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination-container');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }
      let html = '<ul class="pagination">';
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <button class="page-link" onclick="loadRestaurants(${i})">${i}</button></li>`;
      }
      nav.innerHTML = html + '</ul>';
    }

    // Auto-search after typing 1+ characters
    document.getElementById('search-q').addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadRestaurants(1), 300);
    });
    document.getElementById('filter-category').addEventListener('change', () => loadRestaurants(1));
    document.getElementById('filter-rating').addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadRestaurants(1), 400);
    });

    loadCategories();
    loadRestaurants(1);
  </script>
</body>
</html>
