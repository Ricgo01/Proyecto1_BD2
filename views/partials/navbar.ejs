<script>
  const userStr = localStorage.getItem('user');
  if (userStr) {
    const user = JSON.parse(userStr);
    
    // Mostrar nombre del usuario logeado 
    const userInfoEl = document.getElementById('nav-user-info');
    if (userInfoEl) userInfoEl.textContent = `Hola, ${user.name} (${user.role})`;

    // Ocultar sección Owner a clientes
    if (user.role === 'customer') {
      const ownerDropdown = document.getElementById('dropdown-owner');
      if (ownerDropdown) ownerDropdown.style.display = 'none';
    }
  }

  // Cerrar sesión
  const logoutBtn = document.getElementById('logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
      localStorage.removeItem('user');
      window.location.href = '/login';
    });
  }
</script>
