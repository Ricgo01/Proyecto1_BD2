<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <script>
    // Guardián de autenticación del frontend
    if (!localStorage.getItem('user')) {
      window.location.href = '/login';
    }
  </script>
</head>
<body class="bg-light">
  <%- include('partials/navbar') %>

  <div class="container py-4">
    <h1 class="mb-1">Dashboard</h1>
    <p class="text-muted mb-4">Sistema de gestión de restaurantes — BD2 2026</p>

    <!-- Stats cards -->
    <div class="row g-3 mb-5" id="stats">
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <div class="fs-2 fw-bold text-primary" id="stat-restaurants">—</div>
            <div class="small text-muted">Restaurantes</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <div class="fs-2 fw-bold text-success" id="stat-orders">—</div>
            <div class="small text-muted">Pedidos</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <div class="fs-2 fw-bold text-warning" id="stat-reviews">—</div>
            <div class="small text-muted">Reseñas</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <div class="fs-2 fw-bold text-info" id="stat-menuitems">—</div>
            <div class="small text-muted">Items Menú</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <div class="fs-2 fw-bold text-secondary" id="stat-users">—</div>
            <div class="small text-muted">Usuarios</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4" id="role-cards-container">
      <!-- Owner section -->
      <div class="col-md-6" id="ownerCard" style="display: none;">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-dark text-white fw-bold">Owner — Gestion & Mantenimiento</div>
          <div class="card-body d-grid gap-2">
            <a href="/restaurants" class="btn btn-outline-dark text-start">Restaurantes — listar, buscar, filtrar</a>
            <a href="/restaurants/create" class="btn btn-outline-dark text-start">Crear Restaurante</a>
            <a href="/menu" class="btn btn-outline-dark text-start">Menu — listar, editar, toggle</a>
            <a href="/menu/create" class="btn btn-outline-dark text-start">Crear Item de Menu</a>
            <a href="/reports" class="btn btn-outline-dark text-start">Reportes y Agregaciones</a>
            
            <hr class="my-2">
            <div class="text-muted small fw-bold mb-1">Operaciones Masivas (Rúbrica)</div>
            <select id="bulk-restaurantId" class="form-select mb-2">
              <option value="">Selecciona tu restaurante primero...</option>
            </select>
            <button class="btn btn-danger text-start" onclick="bulkDeleteOrders()">Depurar Órdenes Viejas (DeleteMany)</button>
            <button class="btn btn-warning text-dark text-start" onclick="bulkCloseMenu()">Cerrar Todo el Menú (UpdateMany)</button>
          </div>
        </div>
      </div>

      <!-- Customer section -->
      <div class="col-md-6" id="customerCard" style="display: none;">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-primary text-white fw-bold">Cliente — Consumo</div>
          <div class="card-body d-grid gap-2">
            <a href="/orders/create" class="btn btn-outline-primary text-start">Crear Pedido</a>
            <a href="/orders" class="btn btn-outline-primary text-start">Mis Pedidos — listar, filtrar, detalle</a>
            <a href="/reviews/create" class="btn btn-outline-primary text-start">Crear Resena</a>
            <a href="/reviews" class="btn btn-outline-primary text-start">Resenas — listar por restaurante</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Validar Rol al vuelo para modificar la UI
    const storedUser = JSON.parse(localStorage.getItem('user'));
    
    if (storedUser) {
      if (storedUser.role === 'customer') {
        const roleContainer = document.getElementById('role-cards-container');
        document.getElementById('customerCard').style.display = 'block';
        document.getElementById('customerCard').className = 'col-md-12';
        
        // Agregar "Call to Action"
        const ctaDiv = document.createElement('div');
        ctaDiv.className = 'col-md-12 mb-3 mt-4';
        ctaDiv.innerHTML = `
          <div class="alert alert-warning border text-center p-4 rounded shadow-sm">
            <h4 class="alert-heading text-dark fw-bold mb-3">¿Eres dueño de un local?</h4>
            <p class="mb-3">Abre tu restaurante ahora mismo en nuestra plataforma y empieza a gestionar tu menú y ventas al instante.</p>
            <a href="/restaurants/create" class="btn btn-dark btn-lg">¡Abre tu propio restaurante!</a>
          </div>
        `;
        roleContainer.prepend(ctaDiv);
      } 
      else if (storedUser.role === 'owner' || storedUser.role === 'admin') {
        document.getElementById('ownerCard').style.display = 'block';
        document.getElementById('customerCard').style.display = 'block';
      }
    }

    fetch('/api/reports/stats')
      .then(r => r.json())
      .then(data => {
        const s = data.stats;
        document.getElementById('stat-restaurants').textContent = s.totalRestaurants?.toLocaleString() ?? '—';
        document.getElementById('stat-orders').textContent      = s.totalOrders?.toLocaleString() ?? '—';
        document.getElementById('stat-reviews').textContent     = s.totalReviews?.toLocaleString() ?? '—';
        document.getElementById('stat-menuitems').textContent   = s.totalMenuItems?.toLocaleString() ?? '—';
        document.getElementById('stat-users').textContent       = s.totalUsers?.toLocaleString() ?? '—';
      })
      .catch(() => {});

    // --- Seleccion de tu restaurante ---
    async function loadOwnerRestaurantsForBulk() {
      const user = JSON.parse(localStorage.getItem('user'));
      if(!user || (user.role !== 'owner' && user.role !== 'admin')) return;
      try {
        const res = await fetch(`/api/restaurants?owner_id=${user.id}&limit=100`);
        const data = await res.json();
        const sel = document.getElementById('bulk-restaurantId');
        if (data.restaurants && sel) {
          sel.innerHTML = '<option value="">-- Elige un restaurante --</option>';
          data.restaurants.forEach(r => {
            sel.innerHTML += `<option value="${r._id}">${r.name}</option>`;
          });
        }
      } catch (err) {}
    }

    // --- Funciones para Cumplir Rubrica (Updates y Deletes Masivos) ---
    async function bulkDeleteOrders() {
      const rid = document.getElementById('bulk-restaurantId').value;
      if(!rid) return alert('Debes seleccionar un restaurante primero.');

      if(!confirm('🚨 ATENCIÓN 🚨\n¿Deseas depurar (DeleteMany) todas las órdenes canceladas viejas ESTE restaurante?')) return;
      
      try {
        // Enviar restaurantId como Query
        const res = await fetch(`/api/orders/bulk/cancelled?restaurantId=${rid}`, { method: 'DELETE' });
        const data = await res.json();
        
        if (res.ok) alert(`¡Éxito! DeleteMany ejecutado. Se borraron ${data.deletedCount} órdenes canceladas.`);
        else alert(data.error || 'Error al depurar órdenes');
      } catch (e) { alert('Error de red disparando DeleteMany'); }
    }

    async function bulkCloseMenu() {
      const rid = document.getElementById('bulk-restaurantId').value;
      if(!rid) return alert('Debes seleccionar un restaurante primero.');

      if(!confirm('🚨 ATENCIÓN 🚨\n¿Deseas inactivar (UpdateMany) TODOS los platillos de ESTE restaurante para cerrarlo?')) return;
      
      try {
        // Enviar restaurantId en Payload
        const res = await fetch('/api/menu-items/bulk/availability', {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isAvailable: false, restaurantId: rid })
        });
        const data = await res.json();
        
        if (res.ok) alert(`¡Éxito! UpdateMany ejecutado. Se inactivaron ${data.modifiedCount} platillos en tu menú.`);
        else alert(data.error || 'Error cerrando disponibilidad');
      } catch (e) { alert('Error de red disparando UpdateMany'); }
    }

    loadOwnerRestaurantsForBulk();
  </script>
</body>
</html>
