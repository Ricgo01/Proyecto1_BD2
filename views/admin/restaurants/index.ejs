<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Admin — Todos los Restaurantes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <script>
    const _u = JSON.parse(localStorage.getItem('user') || '{}');
    if (!_u.id) window.location.href = '/login';
    if (_u.role !== 'admin') window.location.href = '/';
  </script>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h2 class="mb-0">Todos los Restaurantes</h2>
        <small class="text-muted">Vista Admin — sin filtro de propietario</small>
      </div>
      <a href="/restaurants/create" class="btn btn-dark">+ Nuevo Restaurante</a>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="row g-2">
          <div class="col-md-4">
            <input type="text" id="search-q" class="form-control" placeholder="Buscar por nombre..."/>
          </div>
          <div class="col-md-3">
            <select id="filter-category" class="form-select">
              <option value="">Todas las categorías</option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="number" id="filter-rating" class="form-control" placeholder="Rating min." min="1" max="5" step="0.1"/>
          </div>
          <div class="col-md-2">
            <select id="filter-sort" class="form-select">
              <option value="avgRating">Rating (mayor primero)</option>
              <option value="name">Nombre (A-Z)</option>
              <option value="createdAt">Más nuevos</option>
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-primary w-100" onclick="loadRestaurants(1)">Buscar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla -->
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Categorías</th>
              <th>Rating</th>
              <th>Órdenes</th>
              <th>Dirección</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="restaurants-tbody">
            <tr><td colspan="6" class="text-center py-4 text-muted">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <nav class="mt-3" id="pagination-container"></nav>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let searchTimer;
    // Map restaurantId → orderCount from aggregation
    let orderCountMap = {};

    async function loadCategories() {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('filter-category');
        (data.values?.categories || []).forEach(c => {
          const opt = document.createElement('option');
          opt.value = c; opt.textContent = c;
          sel.appendChild(opt);
        });
      } catch (_) {}
    }

    async function loadOrderCounts() {
      try {
        // Fetch top-restaurants (by order count) to get per-restaurant totals
        const res  = await fetch('/api/reports/top-restaurants?limit=500');
        const data = await res.json();
        (data.restaurants || []).forEach(r => {
          orderCountMap[r._id || r.restaurantId] = r.totalOrders ?? r.orderCount ?? r.count ?? 0;
        });
      } catch (_) {}
    }

    async function loadRestaurants(page = 1) {
      const q        = document.getElementById('search-q').value.trim();
      const category = document.getElementById('filter-category').value;
      const rating   = document.getElementById('filter-rating').value.trim();
      const sort     = document.getElementById('filter-sort').value;

      // Admin: NO owner_id filter → sees all
      const params = new URLSearchParams({ page, limit: 15, sortBy: sort });
      if (q)        params.set('q', q);
      if (category) params.set('category', category);
      if (rating)   params.set('minRating', rating);

      const res  = await fetch(`/api/restaurants?${params}`);
      const data = await res.json();
      const tbody = document.getElementById('restaurants-tbody');

      if (!data.restaurants?.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Sin resultados</td></tr>';
        renderPagination(0, 1);
        return;
      }

      tbody.innerHTML = data.restaurants.map(r => {
        const orders = orderCountMap[r._id] ?? '—';
        return `
        <tr class="align-middle">
          <td>
            ${r.image ? `<img src="/api/images/${r.image}" alt="logo" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" class="me-2">` : ''}
            <strong>${r.name}</strong>
          </td>
          <td>${(r.categories || []).slice(0,3).join(', ') || '—'}</td>
          <td><span class="badge bg-warning text-dark">${r.avgRating?.toFixed(1) ?? '—'}</span></td>
          <td><span class="badge bg-success">${orders}</span></td>
          <td class="text-muted small">${r.address}</td>
          <td class="text-end" style="white-space:nowrap">
            <a href="/restaurants/${r._id}" class="btn btn-sm btn-outline-dark me-1">Ver</a>
            <a href="/restaurants/${r._id}/edit" class="btn btn-sm btn-outline-warning">Editar</a>
          </td>
        </tr>`;
      }).join('');

      renderPagination(data.pagination.pages, page);
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination-container');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }
      let html = '<ul class="pagination">';
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <button class="page-link" onclick="loadRestaurants(${i})">${i}</button></li>`;
      }
      nav.innerHTML = html + '</ul>';
    }

    document.getElementById('search-q').addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadRestaurants(1), 300);
    });
    document.getElementById('filter-category').addEventListener('change', () => loadRestaurants(1));
    document.getElementById('filter-rating').addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadRestaurants(1), 400);
    });

    loadCategories();
    loadOrderCounts().then(() => loadRestaurants(1));
  </script>
</body>
</html>
