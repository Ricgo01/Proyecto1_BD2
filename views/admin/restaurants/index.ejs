<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Admin — Todos los Restaurantes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <script>
    const _u = JSON.parse(localStorage.getItem('user') || '{}');
    if (!_u.id) window.location.href = '/login';
    if (_u.role !== 'admin') window.location.href = '/';
  </script>
</head>
<body class="bg-light">
  <%- include('../../partials/navbar') %>
  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h2 class="mb-0">Todos los Restaurantes</h2>
        <small class="text-muted">Vista Admin — sin filtro de propietario</small>
      </div>
      <div class="d-flex gap-2">
        <button id="bulk-cat-btn" class="btn btn-outline-warning d-none"
          data-bs-toggle="modal" data-bs-target="#cat-modal">
          Ajustar Categorías (<span id="sel-count">0</span>)
        </button>
        <a href="/restaurants/create" class="btn btn-dark">+ Nuevo Restaurante</a>
      </div>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="row g-2">
          <div class="col-md-4">
            <input type="text" id="search-q" class="form-control" placeholder="Buscar por nombre..."/>
          </div>
          <div class="col-md-3">
            <select id="filter-category" class="form-select">
              <option value="">Todas las categorías</option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="number" id="filter-rating" class="form-control" placeholder="Rating min." min="1" max="5" step="0.1"/>
          </div>
          <div class="col-md-2">
            <select id="filter-sort" class="form-select">
              <option value="avgRating">Rating (mayor primero)</option>
              <option value="name">Nombre (A-Z)</option>
              <option value="createdAt">Más nuevos</option>
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-primary w-100" onclick="loadRestaurants(1)">Buscar</button>
          </div>
        </div>
        <div class="row g-2 mt-2">
          <div class="col-md-3">
            <input type="number" id="filter-lat" class="form-control" placeholder="Latitud (ej. 14.6)" step="any"/>
          </div>
          <div class="col-md-3">
            <input type="number" id="filter-lng" class="form-control" placeholder="Longitud (ej. -90.5)" step="any"/>
          </div>
          <div class="col-md-3">
            <input type="number" id="filter-dist" class="form-control" placeholder="Max Distancia (m)" value="5000"/>
          </div>
          <div class="col-md-3 d-flex align-items-center">
            <small class="text-muted">&#128205; Búsqueda Cercana (Geoespacial)</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla -->
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th style="width:36px"><input type="checkbox" id="check-all" class="form-check-input" title="Seleccionar todos" onchange="toggleAll(this.checked)"/></th>
              <th>Nombre</th>
              <th>Categorías</th>
              <th>Rating</th>
              <th>Órdenes</th>
              <th>Dirección</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="restaurants-tbody">
            <tr><td colspan="6" class="text-center py-4 text-muted">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <nav class="mt-3" id="pagination-container"></nav>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let searchTimer;
    // Map restaurantId → orderCount from aggregation
    let orderCountMap = {};
    // Selected restaurant IDs for bulk category ops
    const selectedIds = new Set();

    async function loadCategories() {
      try {
        const res  = await fetch('/api/reports/distinct-values');
        const data = await res.json();
        const sel  = document.getElementById('filter-category');
        (data.values?.categories || []).forEach(c => {
          const opt = document.createElement('option');
          opt.value = c; opt.textContent = c;
          sel.appendChild(opt);
        });
      } catch (_) {}
    }

    async function loadOrderCounts() {
      try {
        // Fetch top-restaurants (by order count) to get per-restaurant totals
        const res  = await fetch('/api/reports/top-restaurants?limit=500');
        const data = await res.json();
        (data.restaurants || []).forEach(r => {
          orderCountMap[r._id || r.restaurantId] = r.totalOrders ?? r.orderCount ?? r.count ?? 0;
        });
      } catch (_) {}
    }

    async function loadRestaurants(page = 1) {
      const q        = document.getElementById('search-q').value.trim();
      const category = document.getElementById('filter-category').value;
      const rating   = document.getElementById('filter-rating').value.trim();
      const sort     = document.getElementById('filter-sort').value;
      const lat      = document.getElementById('filter-lat').value.trim();
      const lng      = document.getElementById('filter-lng').value.trim();
      const dist     = document.getElementById('filter-dist').value.trim();

      // Admin: NO owner_id filter → sees all
      const params = new URLSearchParams({ page, limit: 15, sortBy: sort });
      if (q)        params.set('q', q);
      if (category) params.set('category', category);
      if (rating)   params.set('minRating', rating);

      let url = `/api/restaurants?${params}`;
      if (lat && lng) {
        params.set('lat', lat);
        params.set('lng', lng);
        if (dist) params.set('maxDistance', dist);
        url = `/api/restaurants/nearby?${params}`;
      }

      const res  = await fetch(url);
      const data = await res.json();
      const tbody = document.getElementById('restaurants-tbody');

      if (!data.restaurants?.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Sin resultados</td></tr>';
        renderPagination(0, 1);
        return;
      }

      tbody.innerHTML = data.restaurants.map(r => {
        const orders  = orderCountMap[r._id] ?? '—';
        const checked = selectedIds.has(r._id) ? 'checked' : '';
        return `
        <tr class="align-middle" id="row-${r._id}">
          <td><input type="checkbox" class="form-check-input row-check" value="${r._id}" ${checked}
            onchange="toggleRow('${r._id}',this.checked)"/></td>
          <td>
            ${r.image ? `<img src="/api/images/${r.image}" alt="logo" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" class="me-2">` : ''}
            <strong>${r.name}</strong>
          </td>
          <td class="small">${(r.categories || []).slice(0,4).map(c=>`<span class="badge bg-secondary me-1">${c}</span>`).join('') || '—'}</td>
          <td><span class="badge bg-warning text-dark">${r.avgRating?.toFixed(1) ?? '—'}</span></td>
          <td><span class="badge bg-success">${orders}</span></td>
          <td class="text-muted small">${r.address}</td>
          <td class="text-end" style="white-space:nowrap">
            <a href="/restaurants/${r._id}" class="btn btn-sm btn-outline-dark me-1">Ver</a>
            <a href="/restaurants/${r._id}/edit" class="btn btn-sm btn-outline-warning">Editar</a>
          </td>
        </tr>`;
      }).join('');

      renderPagination(data.pagination.pages, page);
    }

    function renderPagination(totalPages, current) {
      const nav = document.getElementById('pagination-container');
      if (totalPages <= 1) { nav.innerHTML = ''; return; }
      let html = '<ul class="pagination">';
      for (let i = 1; i <= totalPages; i++) {
        html += `<li class="page-item ${i === current ? 'active' : ''}">
          <button class="page-link" onclick="loadRestaurants(${i})">${i}</button></li>`;
      }
      nav.innerHTML = html + '</ul>';
    }

    document.getElementById('search-q').addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadRestaurants(1), 300);
    });
    document.getElementById('filter-category').addEventListener('change', () => loadRestaurants(1));
    document.getElementById('filter-rating').addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadRestaurants(1), 400);
    });

    loadCategories();
    loadOrderCounts().then(() => loadRestaurants(1));
  </script>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- Modal: Ajuste Masivo de Categorías (Admin)             -->
  <!-- ══════════════════════════════════════════════════════ -->
  <div class="modal fade" id="cat-modal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Ajustar Categorías</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted small mb-3">
            Se aplicará a <strong id="modal-sel-count">0</strong> restaurante(s) seleccionado(s).
          </p>
          <!-- Categorías a agregar -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Agregar categorías</label>
            <div class="input-group">
              <input type="text" id="cat-add-input" class="form-control" placeholder="Ej: Italiana"/>
              <button class="btn btn-outline-success" onclick="addCatTag('add')">+ Añadir</button>
            </div>
            <div id="cat-add-tags" class="mt-2 d-flex flex-wrap gap-1"></div>
          </div>
          <!-- Categorías a eliminar -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Eliminar categorías</label>
            <div class="input-group">
              <input type="text" id="cat-rm-input" class="form-control" placeholder="Ej: Comida Rápida"/>
              <button class="btn btn-outline-danger" onclick="addCatTag('rm')">+ Añadir</button>
            </div>
            <div id="cat-rm-tags" class="mt-2 d-flex flex-wrap gap-1"></div>
          </div>
          <div id="cat-modal-alert" class="d-none"></div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button class="btn btn-warning text-dark" onclick="applyBulkCategories()">Aplicar a seleccionados</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ── Selection helpers ──────────────────────────────────
    function toggleRow(id, checked) {
      if (checked) selectedIds.add(id); else selectedIds.delete(id);
      updateSelectionUI();
    }
    function toggleAll(checked) {
      document.querySelectorAll('.row-check').forEach(cb => {
        cb.checked = checked;
        if (checked) selectedIds.add(cb.value); else selectedIds.delete(cb.value);
      });
      updateSelectionUI();
    }
    function updateSelectionUI() {
      const n = selectedIds.size;
      document.getElementById('sel-count').textContent = n;
      document.getElementById('modal-sel-count').textContent = n;
      document.getElementById('bulk-cat-btn').classList.toggle('d-none', n === 0);
      document.getElementById('check-all').indeterminate =
        n > 0 && n < document.querySelectorAll('.row-check').length;
    }

    // ── Category tag chips ────────────────────────────────
    const _catLists = { add: [], rm: [] };
    function addCatTag(type) {
      const inp = document.getElementById(type === 'add' ? 'cat-add-input' : 'cat-rm-input');
      const val = inp.value.trim();
      if (!val || _catLists[type].includes(val)) { inp.value=''; return; }
      _catLists[type].push(val);
      inp.value = '';
      renderCatTags(type);
    }
    document.getElementById('cat-add-input').addEventListener('keydown', e => { if(e.key==='Enter'){e.preventDefault();addCatTag('add');} });
    document.getElementById('cat-rm-input').addEventListener('keydown',  e => { if(e.key==='Enter'){e.preventDefault();addCatTag('rm');} });

    function renderCatTags(type) {
      const container = document.getElementById(type === 'add' ? 'cat-add-tags' : 'cat-rm-tags');
      const color     = type === 'add' ? 'success' : 'danger';
      container.innerHTML = _catLists[type].map((c, i) =>
        `<span class="badge bg-${color} d-flex align-items-center gap-1">${c}
           <button class="btn-close btn-close-white p-0" style="font-size:.6rem"
             onclick="_catLists['${type}'].splice(${i},1);renderCatTags('${type}')"></button>
         </span>`).join('');
    }

    // ── Apply bulk category update ────────────────────────
    async function applyBulkCategories() {
      const alertEl = document.getElementById('cat-modal-alert');
      if (!selectedIds.size) return;
      if (!_catLists.add.length && !_catLists.rm.length) {
        alertEl.className = 'alert alert-warning';
        alertEl.textContent = 'Agrega al menos una categoría para aplicar.';
        alertEl.classList.remove('d-none');
        return;
      }
      try {
        const res  = await fetch('/api/restaurants/bulk/categories', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            restaurantIds:    [...selectedIds],
            addCategories:    _catLists.add,
            removeCategories: _catLists.rm
          })
        });
        const data = await res.json();
        if (res.ok) {
          alertEl.className = 'alert alert-success';
          alertEl.textContent = `✓ ${data.modifiedCount} restaurante(s) actualizados.`;
          alertEl.classList.remove('d-none');
          // Reset tags
          _catLists.add = []; _catLists.rm = [];
          renderCatTags('add'); renderCatTags('rm');
          // Reload list after short delay
          setTimeout(() => {
            bootstrap.Modal.getInstance(document.getElementById('cat-modal')).hide();
            selectedIds.clear(); updateSelectionUI();
            loadOrderCounts().then(() => loadRestaurants(1));
          }, 1200);
        } else {
          alertEl.className = 'alert alert-danger';
          alertEl.textContent = data.error || 'Error al actualizar';
          alertEl.classList.remove('d-none');
        }
      } catch (_) {
        alertEl.className = 'alert alert-danger';
        alertEl.textContent = 'Error de red';
        alertEl.classList.remove('d-none');
      }
    }
    document.getElementById('cat-modal').addEventListener('hidden.bs.modal', () => {
      document.getElementById('cat-modal-alert').classList.add('d-none');
    });
  </script>
</body>
</html>
